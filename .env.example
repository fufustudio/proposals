# Required for production URL, sitemap, canonicals, and OpenGraph metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Proposal access. Keep real proposal passwords in deployment env vars only.
# Local development can use the built-in sample proposal code when these are blank.
PROPOSAL_ACCESS_CODES={"sample-proposal":"demo"}
PROPOSAL_SESSION_SECRET=replace-with-a-long-random-secret

# Optional Search Console verification token for the public index route.
GOOGLE_SITE_VERIFICATION=
