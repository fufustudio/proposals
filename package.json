{
  "name": "fufu-proposals",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "prepare": "husky",
    "typecheck": "next typegen && tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "css-types": "node -e \"require('node:fs').rmSync('.generated/css-types', { recursive: true, force: true })\" && tcm src --pattern \"**/*.module.css\" --allowArbitraryExtensions --outDir .generated/css-types && prettier --write \".generated/css-types/**/*.module.d.css.ts\"",
    "check:generated": "node scripts/check-generated-clean.mjs",
    "components:validate": "node scripts/validate-component-structure.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "playwright:install": "playwright install --with-deps chromium",
    "proposals:clean": "node scripts/check-proposals-clean.mjs",
    "verify:quick": "npm run components:validate && npm run lint && npm run typecheck && npm run test",
    "verify:working": "npm run css-types && npm run components:validate && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build",
    "verify:proposal": "npm run verify:working && npm run check:generated && npm run proposals:clean",
    "verify:handoff": "npm run verify:proposal && npm run test:e2e",
    "verify": "npm run verify:proposal",
    "verify:ci": "npm run verify:proposal && npm run playwright:install && npm run test:e2e",
    "verify:release": "npm run verify:ci && npm run lhci",
    "lhci": "lhci autorun",
    "analyze": "ANALYZE=true next build"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "schema-dts": "^2.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "prettier": "^3.9.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sharp": "^0.35.2",
    "svgo": "^4.0.1",
    "tailwindcss": "^4",
    "typed-css-modules": "^0.9.1",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx,yml,yaml}": "prettier --write --ignore-unknown --no-error-on-unmatched-pattern",
    "*.{js,jsx,ts,tsx,mjs,cjs}": "eslint --fix --no-warn-ignored --no-error-on-unmatched-pattern",
    "src/**/*.module.css": "bash -c 'npm run css-types'"
  }
}
